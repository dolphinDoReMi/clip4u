{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Playwright: Ops console — UI mode",
      "type": "shell",
      "command": "npm run test:e2e:ops:ui",
      "options": {
        "cwd": "${workspaceFolder}/MiraChat",
        "env": {
          "PW_REUSE_SERVERS": "1"
        }
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
