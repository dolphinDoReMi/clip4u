# Copy to `.env` in this directory (same folder as MiraChat/package.json). All apps read that file.
#
# Database: use a local PostgreSQL instance (no Docker in-repo). Example on Linux:
#   sudo service postgresql start   # or your distro’s equivalent
# `npm run mirachat:migrate` creates the database from DATABASE_URL if it does not exist
# (your DB user needs CREATEDB, or run `createdb mirachat` once, or set MIRACHAT_SKIP_ENSURE_DATABASE=1).

# API (run one `npm run dev:api` at a time; a second process on another PORT loads .env fresh and is easy to confuse with an old shell/env)
PORT=4000
DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/mirachat
# Peer auth (common on Linux): DATABASE_URL=postgresql://YOUR_OS_USERNAME@127.0.0.1:5432/mirachat
# MIRACHAT_SKIP_ENSURE_DATABASE=1

TWILIO_GATEWAY_PORT=4010

# Twilio Live — Account SID + Auth Token (webhook X-Twilio-Signature uses live Auth Token)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=

# Twilio Test — for test credentials / mock billing (optional)
TWILIO_TEST_ACCOUNT_SID=
TWILIO_TEST_AUTH_TOKEN=

# Twilio API key (optional; SDK prefers this over primary Auth Token for REST)
# If the key pair is invalid, the gateway now retries with Account SID + Auth Token automatically.
TWILIO_API_KEY_SID=SKxxxxxxxx
TWILIO_API_KEY_SECRET=
TWILIO_SMS_PLUGIN=programmable-messaging
TWILIO_WHATSAPP_PLUGIN=programmable-messaging

TWILIO_SMS_FROM=+15551234567
# Use your Twilio WhatsApp sender (sandbox From is often whatsapp:+14155238886).
TWILIO_WHATSAPP_FROM=whatsapp:+15551234567
# Outbound voice notify (/mirachat/phone/outbound); use a Twilio Voice-capable number you own
TWILIO_VOICE_FROM_NUMBER=
# Optional: longer ring time (1–600 sec) before Twilio stops ringing
# MIRACHAT_TWILIO_VOICE_RING_TIMEOUT=90
# Optional: public HTTPS URL for call status webhooks (initiated, ringing, answered, completed)
# MIRACHAT_TWILIO_VOICE_STATUS_CALLBACK=https://your-ngrok.example/twilio/voice-status
# Optional override for scripts/twilio-voice-probe.mjs callee
# MIRACHAT_VOICE_PROBE_TO=
MIRACHAT_OWNER_PHONE_E164=
# Optional smoke-test recipient. Must be a verified number and must differ from the sender.
# For WhatsApp use the full prefix: whatsapp:+15557654321
TWILIO_TEST_TO=

# Public base URL for signature validation (no trailing slash). In Twilio: Messaging webhook + Status callback → gateway paths below.
TWILIO_WEBHOOK_BASE=
TWILIO_SKIP_SIGNATURE=1
# Twilio console → phone/WhatsApp sender → Status callback URL: {TWILIO_WEBHOOK_BASE or ngrok}/webhooks/twilio/status

MIRACHAT_API_URL=http://127.0.0.1:4000
# Public HTTPS origin of this API (no path). Used to auto-set Twilio Voice StatusCallback for STIR/SHAKEN fields (StirVerstat) in webhooks. Dev: ngrok + MIRACHAT_SKIP_TWILIO_VOICE_WEBHOOK_SIGNATURE=1
# MIRACHAT_PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app
# MIRACHAT_SKIP_TWILIO_VOICE_WEBHOOK_SIGNATURE=1
MIRACHAT_USER_ID=demo-user
TWILIO_POLL_MS=5000

USER_ID=demo-user
WHATSAPP_ACCOUNT_ID=whatsapp-account
WHATSAPP_GATEWAY_PORT=4011
WHATSAPP_POLL_MS=5000
WECHAT_ACCOUNT_ID=wechat-account
WECHATY_NAME=mirachat-gateway
WECHATY_DEBOUNCE_MS=3000
WECHATY_POLL_MS=5000
WECOM_ACCOUNT_ID=wecom-app
WECOM_GATEWAY_PORT=4030
WECOM_WEBHOOK_PATH=/webhooks/wecom/message
WECOM_POLL_MS=5000
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_AGENT_ID=
WECOM_OUTBOUND_ENDPOINT=

MINI_PROGRAM_APP_ID=
MINI_PROGRAM_APP_SECRET=
MINI_PROGRAM_SESSION_SECRET=
MINI_PROGRAM_SESSION_TTL_SECONDS=43200
# Set to 1 so the browser web client (and local tooling) can use POST /mini-program/dev-login — never enable in production.
MINI_PROGRAM_DEV_LOGIN=0

# Telegram gateway default account id (align with gateway-telegram config)
TELEGRAM_ACCOUNT_ID=telegram-account
MIRACHAT_ENABLED=0

# Optional — OpenRouter: analysis assist, thread summaries, three tone-different reply options, and
# POST /mirachat/ingest/desktop-context with `"openRouterAnalysis": true` (conversation analysis memory chunk).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Vision model for POST /mirachat/ingest/desktop-context when the body includes screenshotImageBase64 (defaults to OPENROUTER_MODEL).
# OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://example.com
