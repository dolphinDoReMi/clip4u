page {
  background:
    radial-gradient(circle at top left, rgba(193, 53, 132, 0.2), transparent 30%),
    radial-gradient(circle at top right, rgba(252, 175, 69, 0.16), transparent 24%),
    #0f1014;
  color: #f7f7f8;
  font-family: sans-serif;
}

.screen {
  padding: 24rpx;
}

.card {
  background: rgba(22, 23, 29, 0.94);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 24rpx 72rpx rgba(0, 0, 0, 0.28);
}

.title {
  font-size: 36rpx;
  font-weight: 800;
}

.muted {
  color: #a8a8b3;
}

.pill {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f4c7ea;
  font-size: 24rpx;
  border: 1px solid rgba(255, 79, 216, 0.24);
}

.button-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.primary-btn,
.secondary-btn,
.danger-btn {
  border-radius: 999rpx;
  padding: 0 24rpx;
  border: 1px solid transparent;
}

.primary-btn {
  background: linear-gradient(135deg, #fd1d1d 0%, #f77737 24%, #fcaf45 48%, #c13584 72%, #833ab4 100%);
  color: white;
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.08);
  color: #f7f7f8;
  border-color: rgba(255, 255, 255, 0.08);
}

.danger-btn {
  background: rgba(255, 93, 115, 0.16);
  color: #ffd5dc;
  border-color: rgba(255, 93, 115, 0.22);
}

.label {
  display: block;
  font-size: 24rpx;
  color: #a8a8b3;
  margin-bottom: 8rpx;
}

.text-block {
  white-space: pre-wrap;
  line-height: 1.5;
}

.input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #f7f7f8;
  box-sizing: border-box;
}
